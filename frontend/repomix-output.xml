              <p className="text-slate-100 text-sm font-medium">Викторина «Hardcore QA»</p>
              <p className="text-slate-500 text-xs mt-0.5">
                {gameSettings.quiz_unlocked ? 'Открыта для всех участников' : 'Закрыта'}
