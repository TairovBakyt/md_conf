('Бутылка MDCONF', 'middle', 40, 30),
('Шоппер', 'middle', 60, 30),
('Футболка MDCONF', 'high', 80, 20),
('Подписка на ИТ-сервис (на выбор)', 'high', 90, 15),
('Билет на закрытый Afterparty', 'high', 100, 10);
</file>

