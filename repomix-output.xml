  try {
    const result = await pool.query('SELECT COUNT(*) AS count FROM quiz_lobby');
    return res.json({ count: Number(result.rows[0].count) });
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: 'Ошибка получения количества' });
  }
});

export default router;
</file>

